generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── EXISTING CMS MODELS ──────────────────────────────────────

model Article {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  excerpt          String?
  content          String
  featuredImage    String?
  featuredImageAlt String?
  category         String?
  tags             String[]
  authorName       String    @default("Lather Head Spa")
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  status           String    @default("draft")
  seoTitle         String?
  seoDescription   String?
  readingTime      Int?
  canonicalUrl     String?
  ogImage          String?
}

model Testimonial {
  id              String   @id @default(cuid())
  clientName      String
  testimonialText String
  rating          Int?
  location        String?
  serviceUsed     String?
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GalleryItem {
  id         String   @id @default(cuid())
  imageUrl   String
  altText    String?
  caption    String?
  category   String?
  sortOrder  Int      @default(0)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── BOOKING SYSTEM MODELS ────────────────────────────────────

model BookingService {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  description         String?
  durationMinutes     Int
  price               Int?     // cents, nullable for "inquire" pricing
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(15)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  tier                String?  // "foundation" | "specialized" | "premium"
  featuredImage       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  staffServices  StaffService[]
  appointments   Appointment[]
}

model Staff {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  email               String   @unique
  phone               String?
  bio                 String?
  image               String?
  isActive            Boolean  @default(true)
  calendarSyncEnabled Boolean  @default(false)
  googleCalendarId    String?
  timezone            String   @default("America/New_York")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  staffServices      StaffService[]
  appointments       Appointment[]
  availabilityRules  AvailabilityRule[]
  blackouts          Blackout[]
  googleCalendarToken GoogleCalendarToken?
}

model GoogleCalendarToken {
  id             String    @id @default(cuid())
  staffId        String    @unique
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  scope          String?
  googleEmail    String?
  lastSyncAt     DateTime?
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service BookingService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model AvailabilityRule {
  id        String   @id @default(cuid())
  staffId   String?  // null = location-wide default
  dayOfWeek Int      // 0=Sunday, 1=Monday, ... 6=Saturday
  startTime String   // "10:00" (HH:mm, 24h)
  endTime   String   // "19:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff? @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Blackout {
  id        String   @id @default(cuid())
  staffId   String?  // null = location-wide
  title     String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff? @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id                    String   @id @default(cuid())
  confirmationCode      String   @unique @default(cuid())
  clientId              String
  serviceId             String
  staffId               String
  status                String   @default("pending") // pending | confirmed | completed | no_show | cancelled
  startAt               DateTime
  endAt                 DateTime
  timezone              String   @default("America/New_York")
  notes                 String?  // client-facing notes
  internalNotes         String?  // admin-only notes
  source                String   @default("website") // website | admin
  emailConfirmationSent Boolean  @default(false)
  smsConfirmationSent   Boolean  @default(false)
  reminder24hSent       Boolean  @default(false)
  reminder2hSent        Boolean  @default(false)
  calendarEventId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client  Client         @relation(fields: [clientId], references: [id])
  service BookingService @relation(fields: [serviceId], references: [id])
  staff   Staff          @relation(fields: [staffId], references: [id])
  notifications NotificationLog[]

  @@index([startAt])
  @@index([staffId, startAt])
  @@index([status])
}

model NotificationLog {
  id                String    @id @default(cuid())
  appointmentId     String
  type              String    // email_confirmation | sms_confirmation | email_reminder_24h | sms_reminder_24h | email_reminder_2h | admin_notice
  status            String    @default("pending") // pending | sent | failed
  providerMessageId String?
  sentAt            DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}
